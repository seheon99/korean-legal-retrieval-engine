# Keep the build context small. Bind-mounted paths don't need to be
# in the image either, since they're attached at runtime.

.git/
.gitignore
.env
.env.*

# Bind-mounted at runtime; not baked into the image.
data/
src/
docs/
migrations/
scripts/
tests/

# Python tooling caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
