# Copy to .env and customize. .env is git-ignored.
# docker compose reads .env automatically from the project root.

# ---- Postgres / docker-compose ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legal
# Host port forwarded to the db container (override if 5432 is taken).
DB_PORT=5432

# ---- 법제처 OpenAPI ----
# Used by scripts/fetch_law_samples.sh on the host.
LAW_GO_KR_OC=your-oc-here
